#!/usr/bin/env zsh

SESSIONS=$(zellij list-sessions 2>/dev/null | sed 's/\x1b\[[0-9;]*m//g' | awk '{print $1}')

if [ -z "$SESSIONS" ]; then
  # No sessions, just start fresh
  zellij
else
  # Show simple picker: existing sessions + new option
  CHOICE=$(printf "[ New Session ]\n%s" "$SESSIONS" | fzf \
    --prompt="  ❯ " \
    --header="  Zellij — attach or start new" \
    --height=40% \
    --layout=reverse \
    --border=rounded \
    --margin=1,3 \
    --padding=1,2 \
    --color=bg:-1,bg+:#1f2335 \
    --color=fg:#c0caf5,fg+:#c0caf5 \
    --color=hl:#f7768e,hl+:#f7768e \
    --color=border:#3b4261,header:#7aa2f7 \
    --color=prompt:#bb9af7,pointer:#7dcfff \
    --no-info)

  case "$CHOICE" in
    "[ New Session ]" | "")
      zellij
      ;;
    *)
      zellij attach "$CHOICE"
      ;;
  esac
fi
